# ============================================
# Knotxme Backend — Environment Variables
# Copy this file to ".env" and fill in real values.
# NEVER commit your actual .env file to GitHub.
# ============================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB connection string.
# Local:      mongodb://127.0.0.1:27017/knotxme
# Atlas (recommended for deployment): get this from MongoDB Atlas > Connect > Drivers
MONGO_URI=mongodb://127.0.0.1:27017/knotxme

# JWT
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Frontend URL (used for CORS and for building password-reset links).
# Local dev:  http://localhost:8080
# Production: your Netlify site URL, e.g. https://knotxme.netlify.app
FRONTEND_URL=http://localhost:8080

# SMTP (optional). If left blank, password-reset emails are logged to the
# server console instead of actually being sent — fine for local development.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Knotxme <no-reply@knotxme.in>
